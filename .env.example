# =========================================================================
# harness-creando-mas — Variables de entorno (Fase 0, demo Lovbot)
# =========================================================================
# Copiá este archivo a `.env` y llenálo con valores reales para dev local.
# En Coolify, todas estas vars se setean por UI (NO commitear `.env`).

# -------------------------------------------------------------------------
# Auth del endpoint /chat
# -------------------------------------------------------------------------
# Bearer token global para autenticar requests al harness. Si NO está seteado,
# el servidor arranca en modo abierto (warn en logs). Generá un token con:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
LOVBOT_AGENTE_API_KEY=changeme-bearer-token

# -------------------------------------------------------------------------
# Postgres (Lovbot — Hetzner, red interna Docker `p8s8kcgckgoc484wwo4w8wck_default`)
# -------------------------------------------------------------------------
LOVBOT_PG_HOST=lovbot-postgres-p8s8kcgckgoc484wwo4w8wck
LOVBOT_PG_PORT=5432
LOVBOT_PG_USER=lovbot
LOVBOT_PG_PASS=
LOVBOT_PG_DB=lovbot_crm_modelo

# -------------------------------------------------------------------------
# LLM providers
# -------------------------------------------------------------------------
LOVBOT_OPENAI_API_KEY=sk-...
LOVBOT_GEMINI_API_KEY=AIza...

# -------------------------------------------------------------------------
# Web search (opcional, tool tavily_search)
# -------------------------------------------------------------------------
TAVILY_API_KEY=tvly-...

# -------------------------------------------------------------------------
# Operacional
# -------------------------------------------------------------------------
LOG_LEVEL=INFO

# CORS — orígenes permitidos (CSV). El default ya incluye crm.lovbot.ai +
# localhost dev. Si necesitás agregar más, descomentá:
# CORS_ALLOW_ORIGINS=https://crm.lovbot.ai,http://localhost,http://localhost:8080
